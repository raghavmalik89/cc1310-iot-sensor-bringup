# =========================
# Build output
# =========================
Debug/
Release/

# Nested generated build folders
**/Debug/
**/Release/

# =========================
# Object / compiler output
# =========================
*.obj
*.out
*.d
*.map
*.opt
*.bin

# =========================
# TI / CCS generated files
# =========================
*.rov.json

# Ignore generated target config folders inside projects
**/targetConfigs/

# Optional:
# Keep this ignored unless you intentionally want target config files tracked
# *.ccxml

# =========================
# Clangd / indexing cache
# =========================
.clangd/
.cache/
**/.clangd/
**/.cache/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor files
# =========================
.vscode/

# =========================
# Temporary / export files
# =========================
*.html

# =========================
# Codex workflow assets
# Keep these tracked
# =========================
!Codex_Agents/
!Codex_Agents/**
!Codex_Prompts/
!Codex_Prompts/**